@inherits StockDialogBase

<MudDialog>

    <DialogContent>
        <EditForm EditContext="@EditContext" OnValidSubmit="@OnSubmitEditFormAsync">
            <DataAnnotationsValidator />
            <ServerSideValidation @ref="@ServerSideValidation" />

            <MudCard Elevation="0">
                <MudCardContent>
                    @if (IsNewRecord) 
                    {
                        <MudAutocomplete @bind-Value="@DataObject.StorageLocationID" CoerceText="true" CoerceValue="true" For="@(() => DataObject.StorageLocationID)" Label="Storage Location" MaxItems="null" ResetValueOnEmptyText="false" SearchFunc="@OnStorageLocationAutoCompleteSearchAsync" ToStringFunc="@(id => StorageLocations.FirstOrDefault(obj => obj.Integer64ID == id)?.Name ?? string.Empty)" />
                    }
                    else
                    {
                        <MudTextField @bind-Value="@DataObject.StorageLocationName" Label="Storage Location" ReadOnly="true" />
                    }

                    <MudNumericField @bind-Value="@DataObject.Amount" For="@(() => DataObject.Amount)" Label="Amount" Min="0" Max="@int.MaxValue" />
                </MudCardContent>

                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit">@(IsNewRecord ? "Create" : "Update")</MudButton>
                    <MudButton OnClick="@OnCancelButtonClick">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </EditForm>
    </DialogContent>

</MudDialog>
